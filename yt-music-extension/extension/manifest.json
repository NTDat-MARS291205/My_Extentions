{
  "manifest_version": 3,
  "name": "YT Music Saver",
  "version": "2.0",
  "description": "Tải nhạc YouTube, quản lý thư viện theo thể loại, kiểm tra trùng lặp",
  "permissions": ["activeTab", "scripting", "storage", "nativeMessaging"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:9876/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://localhost:9876"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    { "matches": ["https://www.youtube.com/*"], "js": ["content.js"] }
  ]
}
